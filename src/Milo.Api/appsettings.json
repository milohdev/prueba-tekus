{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=mipruebadb;Username=postgres;Password=postgres;GSS Encryption Mode=Disable"
  },
  "Jwt": {
    "SecretKey": "dev-secret-key-must-be-at-least-32-characters-long!",
    "Issuer": "miprueba-api",
    "Audience": "miprueba-clients",
    "ExpirationMinutes": 480
  },
  "Admin": {
    "Email": "admin@miprueba.com",
    "Password": "Admin1234!"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/miprueba-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Anthropic": {
    "ApiKey": ""
  }
}